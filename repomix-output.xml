  apiVersion: ApiVersion.January25,
  scopes: process.env.SCOPES ? process.env.SCOPES.split(",") : [
    "read_products",
    "read_customers",
    "write_customers",
  ],
  appUrl: process.env.SHOPIFY_APP_URL || "",
