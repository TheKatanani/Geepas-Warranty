{
  "crons": [
    {
      "path": "/cron.process-vouchers",
      "schedule": "*/2 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/public/warranty-register(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
